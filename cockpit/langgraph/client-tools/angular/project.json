{
  "name": "cockpit-langgraph-client-tools-angular",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "cockpit/langgraph/client-tools/angular/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath.base}"
      ],
      "options": {
        "outputPath": {
          "base": "dist/cockpit/langgraph/client-tools/angular",
          "browser": ""
        },
        "browser": "cockpit/langgraph/client-tools/angular/src/main.ts",
        "tsConfig": "cockpit/langgraph/client-tools/angular/tsconfig.app.json",
        "styles": [
          "cockpit/langgraph/client-tools/angular/src/styles.css"
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "1mb",
              "maximumError": "1.5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "10kb",
              "maximumError": "16kb"
            }
          ],
          "outputHashing": "none"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "cockpit/langgraph/client-tools/angular/src/environments/environment.ts",
              "with": "cockpit/langgraph/client-tools/angular/src/environments/environment.development.ts"
            }
          ]
        },
        "cockpit": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "cockpit/langgraph/client-tools/angular/src/environments/environment.ts",
              "with": "cockpit/langgraph/client-tools/angular/src/environments/environment.development.ts"
            }
          ],
          "browser": "cockpit/langgraph/client-tools/angular/src/main.cockpit.ts"
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "cockpit-langgraph-client-tools-angular:build:production"
        },
        "development": {
          "buildTarget": "cockpit-langgraph-client-tools-angular:build:development"
        },
        "cockpit": {
          "buildTarget": "cockpit-langgraph-client-tools-angular:build:cockpit"
        }
      },
      "defaultConfiguration": "development",
      "options": {
        "proxyConfig": "cockpit/langgraph/client-tools/angular/proxy.conf.mjs"
      }
    },
    "smoke": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "cockpit/langgraph/client-tools/angular",
        "command": "npx tsx -e \"import { langgraphClientToolsAngularModule } from './src/index.ts'; const module = langgraphClientToolsAngularModule; if (module.id !== 'langgraph-client-tools-angular' || module.title !== 'LangGraph Client Tools (Angular)') { throw new Error('Unexpected module shape for ' + module.id); }\""
      }
    },
    "e2e": {
      "executor": "@nx/playwright:playwright",
      "options": {
        "config": "cockpit/langgraph/client-tools/angular/e2e/playwright.config.ts"
      }
    }
  },
  "tags": [
    "scope:cockpit-e2e",
    "scope:cockpit-examples"
  ]
}
