{
  "slug": "package-installs-by-package",
  "posthog_id": 8634194,
  "kind": "trends",
  "name": "Package installs by package",
  "events": [
    {
      "event": "ngaf:postinstall",
      "math": "total",
      "properties": [
        {
          "key": "install_context",
          "value": "ci",
          "operator": "is_not"
        }
      ]
    }
  ],
  "breakdown": "pkg",
  "breakdown_limit": 20,
  "interval": "day",
  "date_from": "-30d"
}
