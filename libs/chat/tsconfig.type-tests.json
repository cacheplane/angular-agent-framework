{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc/type-tests",
    "noEmit": true,
    "composite": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "strict": true,
    "noUnusedLocals": false,
    "lib": ["es2022", "dom"],
    "types": []
  },
  "include": ["src/**/*.type-spec.ts", "src/testing/type-assert.ts"]
}
